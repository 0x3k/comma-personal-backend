# ---------------------------------------------------------------------------
# Docker compose knobs (used by docker-compose.yml)
# ---------------------------------------------------------------------------
# Postgres container
POSTGRES_DB=comma
POSTGRES_USER=comma
POSTGRES_PASSWORD=comma
POSTGRES_PORT=5432

# Prod profile (make prod-up)
BACKEND_PORT=7070
FRONTEND_PORT=80
# NEXT_PUBLIC_API_URL is baked into the frontend image at build time.
# Must be reachable from the BROWSER, not from inside the container.
# Note: avoid host port 7000 on macOS -- AirPlay Receiver hijacks it.
NEXT_PUBLIC_API_URL=http://localhost:7070
# Comma-separated list of origins permitted by the CORS middleware.
# Required when the frontend is served from a different origin than the API
# (the docker prod stack puts the frontend on :80 and the API on :7070, so
# they are different origins). Cannot be `*` -- the API uses cookie-based
# session auth and credentialed CORS requests require a specific origin.
# Leave unset to disable CORS entirely (same-origin requests only).
CORS_ALLOWED_ORIGINS=http://localhost
