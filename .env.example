# Required
DATABASE_URL=postgres://comma:comma@localhost:5432/comma?sslmode=disable

# Optional
STORAGE_PATH=./data
PORT=8080

# Restrict which devices can register. Comma-separated hardware serials.
# Pilotauth assigns the dongle_id server-side per the openpilot protocol,
# so the allowlist is keyed on the serial the device reports. If unset,
# all devices are allowed.
# ALLOWED_SERIALS=SERIAL001,SERIAL002

# Web UI authentication. All three variables are optional; UI login is
# disabled entirely when SESSION_SECRET is empty (the server logs a warning
# on startup). Device uploads are unaffected by this setting.
# SESSION_SECRET should be a long random string; generate with e.g.
#   openssl rand -hex 32
# When ADMIN_USERNAME and ADMIN_PASSWORD are both set, the server bootstraps
# or updates that user in the ui_users table on startup, hashing the password
# with bcrypt (cost 12).
# SESSION_SECRET=change-me-to-a-long-random-string
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Docker compose knobs (used by docker-compose.yml)
# ---------------------------------------------------------------------------
# Postgres container
POSTGRES_DB=comma
POSTGRES_USER=comma
POSTGRES_PASSWORD=comma
POSTGRES_PORT=5432

# Prod profile (make prod-up)
BACKEND_PORT=8080
FRONTEND_PORT=3000
# NEXT_PUBLIC_API_URL is baked into the frontend image at build time.
# Must be reachable from the BROWSER, not from inside the container.
NEXT_PUBLIC_API_URL=http://localhost:8080
