{
  "permissions": {
    "allow": [
      "Bash(./.projd/scripts/skill-context.sh:*)",
      "Bash(./.projd/scripts/*)",
      "Bash(git *)",
      "Write",
      "Edit",
      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(gh *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(test *)",
      "Bash(rm *)",
      "Bash(python3 *)",
      "Bash(sqlc *)",
      "Bash(capnp *)",
      "Bash(migrate *)",
      "Bash(ffmpeg *)",
      "Bash(jq *)",
      "Bash(make *)",
      "Bash(curl *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(awk *)",
      "Bash(sed *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"$CLAUDE_PROJECT_DIR\"/.projd/scripts/statusline.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-git-policy.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-worktree-isolation.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
